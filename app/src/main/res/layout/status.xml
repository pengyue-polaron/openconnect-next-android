<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/dashboard_background"
    android:clipToPadding="false"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingTop="12dp"
        android:paddingEnd="24dp"
        android:paddingBottom="32dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/dashboard_wordmark"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:text="@string/app"
                android:textColor="@color/dashboard_primary_text"
                android:textSize="22sp"
                tools:ignore="SelectableText" />

            <ImageButton
                android:id="@+id/dashboard_overflow"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/dashboard_more_options"
                android:padding="12dp"
                android:src="@drawable/ic_more_vert_24" />

        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="48dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/connection_state"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:includeFontPadding="false"
                android:textColor="@color/dashboard_primary_text"
                android:textSize="42sp"
                tools:text="已连接" />

            <FrameLayout
                android:id="@+id/connection_status_badge"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_dashboard_status_icon">

                <ImageView
                    android:layout_width="17dp"
                    android:layout_height="17dp"
                    android:layout_gravity="center"
                    android:contentDescription="@string/dashboard_secure_connection"
                    android:src="@drawable/ic_dashboard_connected_24"
                    app:tint="@color/dashboard_primary_text" />

            </FrameLayout>

        </LinearLayout>

        <TextView
            android:id="@+id/connection_profile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/dashboard_primary_text"
            android:textSize="24sp"
            tools:text="Example" />

        <TextView
            android:id="@+id/connection_time"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:textColor="@color/dashboard_secondary_text"
            android:textSize="15sp"
            tools:text="12:43" />

        <TextView
            android:id="@+id/connection_traffic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:maxLines="1"
            android:textColor="@color/dashboard_secondary_text"
            android:textSize="13sp"
            tools:text="↓ 18.6 MB · ↑ 2.4 MB" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/disconnect_button"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:layout_marginTop="18dp"
            android:minWidth="136dp"
            android:text="@string/disconnect"
            android:textColor="@color/dashboard_accent"
            android:textSize="15sp"
            app:cornerRadius="10dp"
            app:icon="@drawable/ic_power_settings_new_24"
            app:iconGravity="textStart"
            app:iconPadding="12dp"
            app:iconTint="@color/dashboard_accent"
            app:strokeColor="@color/dashboard_accent"
            app:strokeWidth="1dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:background="@drawable/bg_dashboard_card"
            android:clipToOutline="true"
            android:orientation="vertical">

            <LinearLayout
                android:id="@+id/current_profile_row"
                android:layout_width="match_parent"
                android:layout_height="100dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="18dp"
                android:paddingEnd="16dp">

                <FrameLayout
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:background="@drawable/bg_dashboard_icon_well">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:layout_gravity="center"
                        android:contentDescription="@null"
                        android:src="@drawable/ic_dns_24" />

                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="18dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/current_profile_label"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/dashboard_current_profile"
                        android:textColor="@color/dashboard_secondary_text"
                        android:textSize="13sp" />

                    <TextView
                        android:id="@+id/current_profile_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:fontFamily="sans-serif-medium"
                        android:maxLines="1"
                        android:textColor="@color/dashboard_primary_text"
                        android:textSize="20sp"
                        tools:text="Example" />

                    <TextView
                        android:id="@+id/current_profile_server"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:ellipsize="end"
                        android:maxLines="1"
                        android:textColor="@color/dashboard_secondary_text"
                        android:textSize="13sp"
                        tools:text="vpn.example.com" />

                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/dashboard_open_profile"
                    android:src="@drawable/ic_chevron_right_24"
                    app:tint="@color/dashboard_secondary_text" />

            </LinearLayout>

            <View
                android:id="@+id/connection_details_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="@color/dashboard_surface_outline" />

            <LinearLayout
                android:id="@+id/connection_details_row"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/dashboard_connection_details"
                    android:src="@drawable/ic_info_24" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/dashboard_connection_details"
                    android:textColor="@color/dashboard_primary_text"
                    android:textSize="17sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/dashboard_open_connection_details"
                    android:src="@drawable/ic_chevron_right_24"
                    app:tint="@color/dashboard_secondary_text" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="@color/dashboard_surface_outline" />

            <LinearLayout
                android:id="@+id/dashboard_settings_row"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/generalsettings"
                    android:src="@drawable/ic_settings_24"
                    app:tint="@color/dashboard_primary_text" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/generalsettings"
                    android:textColor="@color/dashboard_primary_text"
                    android:textSize="17sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/generalsettings"
                    android:src="@drawable/ic_chevron_right_24"
                    app:tint="@color/dashboard_secondary_text" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp"
                android:background="@color/dashboard_surface_outline" />

            <LinearLayout
                android:id="@+id/dashboard_help_row"
                android:layout_width="match_parent"
                android:layout_height="62dp"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingStart="24dp"
                android:paddingEnd="16dp">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="@string/dashboard_help_about"
                    android:src="@drawable/ic_help_24" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="24dp"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/dashboard_help_about"
                    android:textColor="@color/dashboard_primary_text"
                    android:textSize="17sp" />

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:contentDescription="@string/dashboard_help_about"
                    android:src="@drawable/ic_chevron_right_24"
                    app:tint="@color/dashboard_secondary_text" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</ScrollView>
