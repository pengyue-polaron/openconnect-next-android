<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:orientation="vertical" >
    
    <LinearLayout
        android:id="@+id/log_status_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/stdpadding"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="@dimen/stdpadding"
        android:layout_marginBottom="10dp"
        android:background="@drawable/bg_surface_panel"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp" >

        <View
            android:id="@+id/log_status_dot"
            android:layout_width="9dp"
            android:layout_height="9dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_status_idle" />

        <TextView
            android:id="@+id/speed"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:singleLine="true"
            android:text="@string/speed_waiting"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurface" />

    </LinearLayout>

  <ListView
            android:id="@android:id/list"
            android:transcriptMode="normal"
            android:cacheColorHint="@android:color/transparent"
            android:divider="@color/oc_outline_variant"
            android:dividerHeight="1dp"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    
</LinearLayout>
