<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools" >

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <!-- <uses-permission android:name="android.permission.ACCESS_WIFI_STATE" /> -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" />

    <!-- Copy the <permission> block to your app when using the REMOTE API. Otherwise OConnect
        needs to be installed first -->
    <permission
        android:name="io.pengyue.oconnect.REMOTE_API"
        android:description="@string/permission_description"
        android:label="Control OConnect"
        android:protectionLevel="dangerous" />

    <application
        android:allowBackup="true"
        android:enableOnBackInvokedCallback="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.OConnect"
        android:name="app.openconnect.Application" >
        <activity
            android:name="app.openconnect.ConnectionEditorActivity" />
        <activity
            android:name="app.openconnect.FragActivity" />
        <activity
            android:name="app.openconnect.TokenImportActivity"
            android:exported="true" >

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="http"
                    android:host="127.0.0.1"
                    android:path="/securid/ctf" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="http"
                    android:host="rsa.com"
                    android:path="/android/token/ctf" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="com.rsa.securid" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data android:scheme="com.rsa.securid.iphone" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="file"
                    android:host="*"
                    android:mimeType="*/*"
                    android:pathPattern=".*\\.sdtid" />
            </intent-filter>

            <intent-filter>
                <action android:name="android.intent.action.VIEW" />
                <category android:name="android.intent.category.BROWSABLE" />
                <category android:name="android.intent.category.DEFAULT" />
                <data
                    android:scheme="content"
                    android:host="*"
                    android:mimeType="*/*"
                    android:pathPattern=".*\\.sdtid" />
            </intent-filter>

            </activity>
        <activity android:name="app.openconnect.FileSelect" />
        <activity
            android:name="app.openconnect.MainActivity"
            android:exported="true"
            android:uiOptions="splitActionBarWhenNarrow"
            tools:ignore="ExportedActivity" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name="org.acra.CrashReportDialog"
            android:theme="@style/Theme.OConnect.Dialog"
            android:launchMode="singleInstance"
            android:excludeFromRecents="true"
            android:finishOnTaskLaunch="true" />

        <service
            android:name="app.openconnect.core.OpenVpnService"
            android:exported="true"
            android:foregroundServiceType="systemExempted"
            android:permission="android.permission.BIND_VPN_SERVICE"
            tools:ignore="ForegroundServicePermission" >
            <intent-filter>
                <action android:name="android.net.VpnService" />
            </intent-filter>
        </service>

        <service
            android:name="app.openconnect.core.QuickSettingsTileService"
            android:exported="true"
            android:icon="@drawable/ic_stat_vpn"
            android:label="@string/quick_settings_label"
            android:permission="android.permission.BIND_QUICK_SETTINGS_TILE" >
            <intent-filter>
                <action android:name="android.service.quicksettings.action.QS_TILE" />
            </intent-filter>
            <meta-data
                android:name="android.service.quicksettings.TOGGLEABLE_TILE"
                android:value="true" />
        </service>
<!--
        <service
            android:name="app.openconnect.api.ExternalOpenVPNService"
            android:permission="io.pengyue.oconnect.REMOTE_API" >
            <intent-filter>
                <action android:name="io.pengyue.oconnect.api.IOpenVPNAPIService" />
            </intent-filter>
        </service>
-->

        <activity
            android:exported="true"
            android:permission="io.pengyue.oconnect.REMOTE_API"
            android:name="app.openconnect.api.GrantPermissionsActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>
        <activity
            android:exported="true"
            android:permission="io.pengyue.oconnect.REMOTE_API"
            android:name="app.openconnect.api.ConfirmDialog" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>

        <receiver
            android:name="app.openconnect.OnBootReceiver"
            android:exported="true" >
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <provider
            android:name="app.openconnect.FileProvider"
            android:authorities="io.pengyue.oconnect.FileProvider"
            android:exported="false"
            android:grantUriPermissions="true"
            tools:ignore="ExportedContentProvider" />

        <!--
        <receiver android:name="core.GetRestrictionReceiver">
            <intent-filter>
                <action android:name="android.intent.action.GET_RESTRICTION_ENTRIES" />
            </intent-filter>
        </receiver>
        -->

        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposeddescription"
            android:value="Bypass Android VPN confirmation dialog" />
        <meta-data
            android:name="xposedminversion"
            android:value="30" />

    </application>

</manifest>
